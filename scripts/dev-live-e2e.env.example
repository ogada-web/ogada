# Live E2E (실백엔드 Vitest) — scripts/run-live-e2e.sh와 npm run test:live-e2e가 source 합니다.
# ./scripts/setup-dev-live-e2e-env.sh 또는 cp scripts/dev-live-e2e.env.example scripts/dev-live-e2e.env
# 후 값 조정 (비밀값 커밋 금지 — scripts/*.env 는 .gitignore).
#
# 백엔드 bootstrap API는 일반 dev 기동 시 OFF입니다 (scripts/dev-backend.env).
# Live E2E 실행 전에만 백엔드를 아래처럼 재기동하세요:
#   export LIVE_E2E_BOOTSTRAP_ENABLED=1
#   (기존 백엔드 프로세스 종료 후 dev-backend.env 로 다시 기동)

export LIVE_E2E=1
export VITE_API_BASE="${VITE_API_BASE:-http://127.0.0.1:8080}"

# staff 계정 (hq_admin 권장) — LIVE_E2E_ACCESS_TOKEN 미설정 시 필수
export LIVE_E2E_EMAIL="${LIVE_E2E_EMAIL:-test@test.com}"
export LIVE_E2E_PASSWORD="${LIVE_E2E_PASSWORD:-ogada1234}"

# 미리 발급한 JWT가 있다면 로그인 대신 사용 (선택)
# export LIVE_E2E_ACCESS_TOKEN=""
# export LIVE_E2E_REFRESH_TOKEN=""

# J01 초대·보호자 API (미설정 시 scripts/run-live-e2e.sh가 DB에서 active client 1건 조회)
# export LIVE_E2E_CLIENT_ID="00000000-0000-0000-0000-000000000001"

# J02 보호자 포털 커버리지 (guardian 계정 시드 필요)
# GUARDIAN_* 별칭도 지원: 기존 운영 셸 변수 재사용 시 활용
# 기본 시드: live-e2e-guardian@ogada.test / ogada-guardian-e2e
# export GUARDIAN_EMAIL="live-e2e-guardian@ogada.test"
# export GUARDIAN_PASSWORD="ogada-guardian-e2e"
# export LIVE_E2E_GUARDIAN_EMAIL="live-e2e-guardian@ogada.test"
# export LIVE_E2E_GUARDIAN_PASSWORD="ogada-guardian-e2e"

# US-T02 배차 생성·확정·취소 등 DB를 변경하는 시나리오 — 로컬/스테이징 전용, 기본 off
# export LIVE_E2E_WRITE=1
